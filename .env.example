# 🔑 Переменные окружения для NutriBuddy Bot
# Скопируйте этот файл в .env и заполните реальные значения

# 🤖 Telegram Bot (обязательно)
BOT_TOKEN=your_bot_token_here

# 👤 Администратор бота (ID Telegram пользователя)
ADMIN_ID=123456789

# 🌐 Webhook настройки (для продакшена)
WEBHOOK_URL=https://your-service-name.onrender.com
PORT=8080

# 🗄️ База данных (обязательно)
DATABASE_URL=sqlite:///nutribuddy.db
# Или для PostgreSQL: postgresql://user:password@host:port/database

# 🔄 Redis для FSM (обязательно для продакшена)
REDIS_URL=redis://localhost:6379/0

# 🧠 Cloudflare Workers AI (обязательно для фотоанализа)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# 🌤️ Погода (WeatherAPI.com - 1M запросов/мес бесплатно)
WEATHERAPI_KEY=your_weatherapi_key

# 📊 Настройки логирования
LOG_LEVEL=INFO
LOG_TO_FILE=false

# 🚀 Окружение
RAILWAY_ENVIRONMENT=production
