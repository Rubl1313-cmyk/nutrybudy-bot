# 🔑 Переменные окружения для Render
# Скопируйте эти переменные в Environment Variables вашего Render сервиса

# 🤖 Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# 🗄️ База данных (PostgreSQL предоставляется Render)
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database

# 🌐 Webhook настройки
WEBHOOK_URL=https://your-service-name.onrender.com
PORT=8080

# 🧠 Cloudflare Workers AI (Hermes)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
HERMES_MODEL_ID=@cf/meta/llama-3.1-8b-instruct

# 📸 Llama Vision для распознавания еды
LLAMA_VISION_MODEL_ID=@cf/meta/llama-3.2-11b-vision-instruct

# 🌤️ Погода (OpenWeatherMap)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# 📊 Опционально
ADMIN_ID=your_telegram_user_id
LOG_TO_FILE=true
RAILWAY_ENVIRONMENT=production
