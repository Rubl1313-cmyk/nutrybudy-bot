import logging
import json
from typing import Dict, List, Optional, Any
from datetime import datetime, timedelta
from sqlalchemy import select
from services.ai_engine_manager import ai
from database.db import get_session
from database.models import User, Meal, WeightEntry, Activity

logger = logging.getLogger(__name__)

class EnhancedAIParser:
    """Улучшенный AI парсер с многократными попытками и валидацией"""
    
    def __init__(self):
        self.max_retries = 3
        self.confidence_threshold = 70
    
    async def parse_food_enhanced(
        self, 
        text: str, 
        context: Dict = None, 
        history: List[str] = None
    ) -> Dict:
        """
        Улучшенный парсер еды с AI
        """
        prompt = f"""
        Ты - умный ассистент NutriBuddy. Проанализируй текст о еде с максимальной точностью.
        
        📝 ТЕКСТ: "{text}"
        
        📚 КОНТЕКСТ:
        {self._format_context(context)}
        
        📜 ИСТОРИЯ ДИАЛОГА:
        {self._format_history(history)}
        
        🎯 ПРАВИЛА ПАРСИНГА:
        
        1. **Продукты:**
           - Извлеки все упомянутые продукты
           - Определи количество и единицы измерения
           - Учитывай синонимы и разговорные названия
           - Примеры: "курица" → "куриное филе", "картошка" → "картофель"
           
        2. **Количество:**
           - Определи точный вес/объем
           - При отсутствии укажи стандартные порции:
           * Мясо/рыба: 100-200г
           * Гарниры: 150-200г  
           * Фрукты: 1 шт = 150г
           * Овощи: 100-200г
           
        3. **Способ приготовления:**
           - Определи по контексту или запроси уточнение
           - Варианты: жареный, вареный, запеченный, тушеный, на пару, сырый
           - Учитывай влияние на калорийность:
           * Жареный: +20% калорийности
           * Вареный: базовая калорийность
           * Запеченный: +10% калорийности
           * Тушеный: базовая калорийность
           * На пару: -5% калорийности
           
        4. **Тип приема пищи:**
           - Определи по времени и контексту
           - Завтрак: 6:00-11:00
           - Обед: 11:00-16:00
           * Ужин: 16:00-22:00
           * Перекус: любое время
           
        5. **Валидация:**
           - Проверяй реалистичность количеств
           - 1000 кг мяса -> нереалистично, запросить уточнение
           - 0.1 г соли -> слишком мало, но возможно
           
        📋 ВЕРНИ JSON:
        {{
            "food_items": [
                {{
                    "name": "название продукта",
                    "quantity": количество в числах,
                    "unit": "г|кг|шт|мл|л|ложка|стакан",
                    "preparation": "жареный|вареный|тушеный|запеченный|на пару",
                    "confidence": 0-100
                }}
            ],
            "meal_type": "завтрак|обед|ужин|перекус|неизвестно",
            "total_confidence": 0-100,
            "needs_clarification": true/false,
            "clarification": "уточняющий вопрос если нужно"
        }}
        
        Примеры:
        "съел 200г жареной курицы с гречкой" -> {{
            "food_items": [
                {{"name": "курица", "quantity": 200, "unit": "г", "preparation": "жареный"}},
                {{"name": "гречка", "quantity": 150, "unit": "г", "preparation": "вареный"}}
            ],
            "meal_type": "обед"
        }}
        
        "половина авокадо и 2 яйца пашот" -> {{
            "food_items": [
                {{"name": "авокадо", "quantity": 100, "unit": "г", "preparation": "сырое"}},
                {{"name": "яйца", "quantity": 2, "unit": "шт", "preparation": "пашот"}}
            ]
        }}
        """
        
        try:
            result = await ai.process_text(prompt, task_type="json", system_prompt="You are nutrition expert. Return JSON only.")
            
            logger.info(f"🧠 AI result success: {result.get('success', False)}")
            
            if result.get("success"):
                response_data = result.get("data", {})
                
                # Получаем текстовый контент из разных форматов ответа
                if isinstance(response_data, dict):
                    if "content" in response_data:
                        # Если content это dict, берем его как строку
                        content = response_data.get("content")
                        if isinstance(content, dict):
                            # Если content это dict с JSON структурой, используем его напрямую
                            if "intent" in content or "food_items" in content:
                                response_text = json.dumps(content)  # Конвертируем в JSON строку
                            else:
                                response_text = str(content)
                        else:
                            response_text = str(content)
                    else:
                        response_text = str(response_data)
                else:
                    response_text = str(response_data)
                
                logger.info(f"🧠 AI response text: {response_text[:200] if len(response_text) > 200 else response_text}...")
                
                import re
                json_match = re.search(r'\{.*\}', response_text, re.DOTALL)
                
                if json_match:
                    try:
                        parsed_data = json.loads(json_match.group())
                        logger.info(f"🧠 AI parsed data keys: {list(parsed_data.keys())}")
                        
                        # Преобразуем entities в food_items для совместимости
                        if 'entities' in parsed_data and 'food_items' in parsed_data['entities']:
                            parsed_data['food_items'] = parsed_data['entities']['food_items']
                        
                        # Если нет food_items, создаем пустой список
                        if 'food_items' not in parsed_data:
                            parsed_data['food_items'] = []
                        
                        total_confidence = parsed_data.get("confidence", 50)  # Значение по умолчанию 50%
                        parsed_data["total_confidence"] = total_confidence
                        
                        # При низкой уверенности запрашиваем уточнение
                        if total_confidence < 70:
                            parsed_data["needs_clarification"] = True
                            parsed_data["clarification"] = "Пожалуйста, уточните продукты и их количество"
                        
                        logger.info(f"🧠 Enhanced AI food: {len(parsed_data.get('food_items', []))} items (confidence: {total_confidence}%%)")
                        return parsed_data
                    except json.JSONDecodeError as e:
                        logger.error(f"🧠 JSON decode error: {e}")
                        logger.error(f"🧠 Raw JSON: {json_match.group()}")
                        return self._fallback_food(text)
                else:
                    logger.warning("🧠 Enhanced AI food parser format invalid - no JSON found")
                    logger.warning(f"🧠 Response text: {response_text}")
                    return self._fallback_food(text)
            else:
                error_msg = result.get("error", "Unknown error")
                logger.warning(f"🧠 Enhanced AI food parsing failed: {error_msg}")
                return self._fallback_food(text)
                
        except Exception as e:
            logger.error(f"🧠 Enhanced AI food parser error: {e}")
            # Возвращаем ошибку вместо fallback - заставляем использовать AI
            return {
                "food_items": [],
                "meal_type": "неизвестно",
                "total_confidence": 0,
                "needs_clarification": True,
                "error": "AI parsing failed"
            }
    
    async def parse_water_enhanced(self, text: str) -> Dict:
        """Улучшенный парсер воды"""
        prompt = f"""
        Ты - умный ассистент NutriBuddy. Проанализируй текст о воде и определи точное количество.

        Текст: "{text}"

        ВАЖНО: Верни ТОЛЬКО JSON в формате:
        {{
            "amount_ml": количество_в_мл,
            "unit": "мл",
            "confidence": 0-100
        }}

        ПРИМЕРЫ:
        - "выпил большую кружку чая" -> {{"amount_ml": 300, "unit": "мл", "confidence": 85}}
        - "выпил стакан воды" -> {{"amount_ml": 250, "unit": "мл", "confidence": 90}}
        - "выпил полтора литра воды" -> {{"amount_ml": 1500, "unit": "мл", "confidence": 95}}
        - "выпил бутылку воды" -> {{"amount_ml": 500, "unit": "мл", "confidence": 90}}

        Анализируй контекст: "большую кружку" = 250-350мл, "стакан" = 200-250мл, "бутылка" = 500мл.
        """
        
        try:
            result = await ai.process_text(prompt, task_type="json")
            
            if result.get("success"):
                response_data = result.get("data", {})
                
                # Получаем текстовый контент из разных форматов ответа
                if isinstance(response_data, dict):
                    if "content" in response_data:
                        content = response_data.get("content")
                        if isinstance(content, dict):
                            response_text = str(content)
                        else:
                            response_text = str(content)
                    else:
                        response_text = str(response_data)
                else:
                    response_text = str(response_data)
                
                import re
                json_match = re.search(r'\{.*\}', response_text, re.DOTALL)
                
                if json_match:
                    import json
                    parsed_data = json.loads(json_match.group())
                    
                    amount = parsed_data.get("amount_ml", 0)
                    confidence = parsed_data.get("confidence", 0)
                    
                    logger.info(f"🧠 Enhanced AI water: {amount} мл (confidence: {confidence}%%)")
                    return parsed_data
            
            return self._fallback_water(text)
            
        except Exception as e:
            logger.error(f"🧠 Enhanced AI water parser error: {e}")
            # Возвращаем ошибку вместо fallback - заставляем использовать AI
            return {
                "amount_ml": 0,
                "unit": "мл",
                "confidence": 0,
                "needs_clarification": True,
                "error": "AI parsing failed"
            }
    
    async def parse_activity_enhanced(self, text: str) -> Dict:
        """Улучшенный парсер активности"""
        prompt = f"""
        Ты - умный ассистент NutriBuddy. Проанализируй текст о физической активности.

        Текст: "{text}"

        ВАЖНО: Верни ТОЛЬКО JSON в формате:
        {{
            "activity_type": "бег|ходьба|тренировка|плавание|велосипед",
            "duration_minutes": продолжительность_в_минутах,
            "intensity": "низкая|средняя|высокая",
            "calories_estimate": примерные_калории,
            "confidence": 0-100
        }}

        ПРИМЕРЫ:
        - "интенсивная тренировка в зале 45 минут" -> {{"activity_type": "тренировка", "duration_minutes": 45, "intensity": "высокая", "calories_estimate": 540, "confidence": 90}}
        - "бегал 5 км за 30 минут" -> {{"activity_type": "бег", "duration_minutes": 30, "intensity": "средняя", "calories_estimate": 240, "confidence": 85}}
        - "спокойная ходьба 20 минут" -> {{"activity_type": "ходьба", "duration_minutes": 20, "intensity": "низкая", "calories_estimate": 100, "confidence": 90}}

        Анализируй интенсивность: "интенсивная" = высокая, "спокойная" = низкая, без уточнения = средняя.
        """
        
        try:
            result = await ai.process_text(prompt, task_type="json")
            
            if result.get("success"):
                response_data = result.get("data", {})
                
                # Получаем текстовый контент из разных форматов ответа
                if isinstance(response_data, dict):
                    if "content" in response_data:
                        content = response_data.get("content")
                        if isinstance(content, dict):
                            response_text = str(content)
                        else:
                            response_text = str(content)
                    else:
                        response_text = str(response_data)
                else:
                    response_text = str(response_data)
                
                import re
                json_match = re.search(r'\{.*\}', response_text, re.DOTALL)
                
                if json_match:
                    import json
                    parsed_data = json.loads(json_match.group())
                    
                    activity_type = parsed_data.get("activity_type", "неизвестно")
                    confidence = parsed_data.get("confidence", 0)
                    
                    logger.info(f"🧠 Enhanced AI activity: {activity_type} (confidence: {confidence}%%)")
                    return parsed_data
            
            return self._fallback_activity(text)
            
        except Exception as e:
            logger.error(f"🧠 Enhanced AI activity parser error: {e}")
            # Возвращаем ошибку вместо fallback - заставляем использовать AI
            return {
                "activity_type": "неизвестно",
                "duration_minutes": 0,
                "intensity": "неизвестно",
                "confidence": 0,
                "needs_clarification": True,
                "error": "AI parsing failed"
            }
    
    async def analyze_intent(self, text: str, context: Dict = None) -> Dict:
        """Анализ намерения (совместимость с тестами)"""
        return await self.classify_intent_enhanced(text, context)
    
    async def validate_input_semantic(self, input_type: str, value: Any) -> Dict:
        """Семантическая валидация ввода"""
        if input_type == 'weight':
            # Проверяем реалистичность веса
            if isinstance(value, (int, float)):
                if value < 30 or value > 300:
                    return {"realistic": False, "reason": "Вес вне реалистичного диапазона"}
                else:
                    return {"realistic": True, "reason": "Вес в нормальном диапазоне"}
            else:
                return {"realistic": False, "reason": "Некорректный тип данных"}
        else:
            return {"realistic": True, "reason": "Тип не требует валидации"}
    
    async def classify_intent_enhanced(
        self, 
        text: str, 
        context: Dict = None, 
        history: List[str] = None
    ) -> Dict:
        """Улучшенный классификатор намерений"""
        prompt = f"""
        Ты - умный ассистент NutriBuddy. Проанализируй намерение пользователя с максимальной точностью.
        
        📝 ТЕКСТ: "{text}"
        
        📚 КОНТЕКСТ:
        {self._format_context(context)}
        
        📜 ИСТОРИЯ ДИАЛОГА:
        {self._format_history(history)}
        
        🎯 КЛАССИФИКАТОР НАМЕРЕНИЙ:
        
        1. **food** - пользователь хочет записать прием пищи
           Примеры: "съел", "завтракал", "обед", "ужин", "перекус", "поесть"
           Ключевые слова: съел, поел, завтрак, обед, ужин, перекус, голоден
           
        2. **water** - пользователь хочет записать воду
           Примеры: "выпил", "вода", "жидкость", "пить"
           Ключевые слова: выпил, вода, пить, жажда, стакан, бутылка
           
        3. **activity** - пользователь хочет записать активность
           Примеры: "бегал", "ходил", "тренировка", "спорт", "физическая активность"
           Ключевые слова: бегал, ходил, тренировка, спорт, активность, упражнения
           
        4. **steps** - пользователь хочет записать шаги
           Примеры: "шаги", "прошел", "ходьба", "педометр"
           Ключевые слова: шаги, прошел, ходьба, педометр, шаг
           
        5. **weight** - пользователь хочет записать вес
           Примеры: "вес", "масса", "взвесился", "килограммы"
           Ключевые слова: вес, масса, взвесился, кг, килограммы
           
        6. **question** - пользователь задает вопрос
           Примеры: "как", "почему", "что", "когда", "сколько"
           Ключевые слова: ?, как, почему, что, когда, сколько, помочь
           
        7. **help** - пользователь запрашивает помощь
           Примеры: "помощь", "помоги", "инструкция", "как пользоваться"
           Ключевые слова: помощь, помоги, инструкция, guide, как пользоваться
           
        8. **other** - все остальные случаи
        
        🧠 АНАЛИЗ:
        - Учитывай контекст и историю диалога
        - Определяй синонимы и разговорные выражения
        - При низкой уверенности (<70%) запрашивай уточнение
        - Различай похожие фразы: "купил курицу" (не еда) vs "съел курицу" (еда)
        
        📋 ВЕРНИ JSON:
        {{
            "intent": "food|water|activity|steps|weight|question|help|other",
            "confidence": 0-100,
            "entities": {{
                "food_items": [{{"name": "...", "quantity": ..., "unit": "..."}}],
                "water_amount": ...,
                "activity_type": "...",
                "duration": ...,
                "steps_count": ...,
                "weight_kg": ...
            }},
            "needs_clarification": true/false,
            "clarification_question": "уточняющий вопрос если нужно"
        }}
        
        """
        
        try:
            result = await ai.process_text(prompt, task_type="json", system_prompt="You are NutriBuddy assistant. Return JSON only.")
            
            logger.info(f"🧠 Intent AI result success: {result.get('success', False)}")
            
            if result.get("success"):
                response_data = result.get("data", {})
                
                # Получаем текстовый контент из разных форматов ответа
                if isinstance(response_data, dict):
                    if "content" in response_data:
                        # Если content это dict, берем его как строку
                        content = response_data.get("content")
                        if isinstance(content, dict):
                            # Если content это dict с JSON структурой, используем его напрямую
                            if "intent" in content or "food_items" in content:
                                response_text = json.dumps(content)  # Конвертируем в JSON строку
                            else:
                                response_text = str(content)
                        else:
                            response_text = str(content)
                    else:
                        response_text = str(response_data)
                else:
                    response_text = str(response_data)
                
                logger.info(f"🧠 Intent AI response: {response_text[:200] if len(response_text) > 200 else response_text}...")
                
                import re
                json_match = re.search(r'\{.*\}', response_text, re.DOTALL)
                
                if json_match:
                    try:
                        parsed_data = json.loads(json_match.group())
                        logger.info(f"🧠 Intent parsed keys: {list(parsed_data.keys())}")
                        
                        intent = parsed_data.get('intent', 'other')
                        confidence = parsed_data.get('confidence', 0)
                        
                        logger.info(f"🧠 Enhanced AI intent: {intent} (confidence: {confidence}%%)")
                        return parsed_data
                    except json.JSONDecodeError as e:
                        logger.error(f"🧠 Intent JSON decode error: {e}")
                        logger.error(f"🧠 Raw JSON: {json_match.group()}")
                        return self._fallback_intent(text)
                else:
                    logger.warning("🧠 Intent format invalid - no JSON found")
                    logger.warning(f"🧠 Response text: {response_text}")
                    return self._fallback_intent(text)
            else:
                error_msg = result.get("error", "Unknown error")
                logger.warning(f"🧠 Intent parsing failed: {error_msg}")
                return self._fallback_intent(text)
            
        except Exception as e:
            logger.error(f"🧠 Intent parse error: {e}")
            # Возвращаем ошибку вместо fallback - заставляем использовать AI
            return {
                "intent": "other",
                "confidence": 0,
                "entities": {},
                "needs_clarification": True,
                "error": "AI parsing failed"
            }
    
    async def multi_task_parse(
        self,
        text: str,
        context: Dict = None,
        history: List[str] = None
    ) -> Dict:
        """
        Многозадачный парсер - один вызов AI для всех задач
        """
        
        # Сначала проверим комбинированные запросы с помощью эвристики
        text_lower = text.lower()
        has_food = any(word in text_lower for word in ['съел', 'ел', 'запиши', 'г', 'кг', 'грамм'])
        has_water = any(word in text_lower for word in ['выпил', 'вод', 'мл', 'литр'])
        has_activity = any(word in text_lower for word in ['бегал', 'тренировка', 'ходил'])
        
        # Если это комбинированный запрос, обрабатываем по частям
        if (has_food + has_water + has_activity) >= 2:
            result = {
                "intent": "multi_task",
                "confidence": 90,
                "entities": {},
                "response": "Записываю несколько действий",
                "actions": [],
                "needs_clarification": False
            }
            
            # Обрабатываем еду
            if has_food:
                food_result = await self.parse_food_enhanced(text)
                if food_result.get('food_items'):
                    result["entities"]["food_items"] = food_result['food_items']
                    result["actions"].append({
                        "type": "save_food",
                        "data": {"food_items": food_result['food_items']}
                    })
            
            # Обрабатываем воду
            if has_water:
                water_result = await self.parse_water_enhanced(text)
                if water_result.get('amount_ml'):
                    result["entities"]["water_amount"] = water_result['amount_ml']
                    result["actions"].append({
                        "type": "save_water", 
                        "data": {"amount_ml": water_result['amount_ml']}
                    })
            
            # Обрабатываем активность
            if has_activity:
                activity_result = await self.parse_activity_enhanced(text)
                if activity_result.get('activity_type'):
                    result["entities"]["activity_type"] = activity_result['activity_type']
                    result["actions"].append({
                        "type": "save_activity",
                        "data": activity_result
                    })
            
            return result
        
        # Для обычных запросов используем AI
        prompt = f"""
        Ты - умный ассистент NutriBuddy. Выполни комплексный анализ сообщения за один раз.
        
        📝 ТЕКСТ: "{text}"
        
        📚 КОНТЕКСТ:
        {self._format_context(context)}
        
        📜 ИСТОРИЯ:
        {self._format_history(history)}
        
        🎯 ЗАДАЧИ:
        1. Определи намерение (intent)
        2. Извлеки сущности (entities)
        3. Сформируй ответ (response)
        4. Определи действия (actions)
        
        🧠 НАМЕРЕНИЯ:
        - food: записать прием пищи
        - water: записать воду
        - activity: записать активность
        - steps: записать шаги
        - weight: записать вес
        - question: ответить на вопрос
        - help: показать помощь
        - other: другие случаи
        
        📋 ВЕРНИ JSON:
        {{
            "intent": "намерение",
            "confidence": 0-100,
            "entities": {{
                "food_items": [...],
                "water_amount": ...,
                "activity_type": "...",
                "steps_count": ...,
                "weight_kg": ...
            }},
            "response": "текст ответа пользователю",
            "actions": [
                {{
                    "type": "save_food|save_water|save_activity|save_steps|save_weight|answer_question|show_help",
                    "data": {...}
                }}
            ],
            "needs_clarification": true/false,
            "clarification": "уточняющий вопрос если нужно"
        }}
        
        Примеры:
        {{"text": "Я съел яблоко"}} -> {{{{"food_items": [{{"name": "яблоко", "quantity": 1, "unit": "шт"}}], "meal_type": "завтрак", "total_confidence": 80}}}}
        """
        
        try:
            result = await ai.process_text(prompt, task_type="json", system_prompt="You are NutriBuddy assistant. Return JSON only.")
            
            logger.info(f"🧠 Multi-task AI result success: {result.get('success', False)}")
            
            if result.get("success"):
                response_data = result.get("data", {})
                
                # Получаем текстовый контент из разных форматов ответа
                if isinstance(response_data, dict):
                    if "content" in response_data:
                        # Если content это dict, берем его как строку
                        content = response_data.get("content")
                        if isinstance(content, dict):
                            # Если content это dict с JSON структурой, используем его напрямую
                            if "intent" in content or "food_items" in content:
                                response_text = json.dumps(content)  # Конвертируем в JSON строку
                            else:
                                response_text = str(content)
                        else:
                            response_text = str(content)
                    else:
                        response_text = str(response_data)
                else:
                    response_text = str(response_data)
                
                logger.info(f"🧠 Multi-task AI response: {response_text[:200] if len(response_text) > 200 else response_text}...")
                
                import re
                json_match = re.search(r'\{.*\}', response_text, re.DOTALL)
                
                if json_match:
                    try:
                        parsed_data = json.loads(json_match.group())
                        logger.info(f"🧠 Multi-task parsed keys: {list(parsed_data.keys())}")
                        
                        intent = parsed_data.get('intent', 'unknown')
                        confidence = parsed_data.get('confidence', 0)
                        
                        logger.info(f"🧠 Multi-task parse: {intent} (confidence: {confidence}%%)")
                        return parsed_data
                    except json.JSONDecodeError as e:
                        logger.error(f"🧠 Multi-task JSON decode error: {e}")
                        logger.error(f"🧠 Raw JSON: {json_match.group()}")
                        return self._fallback_multi_task(text)
                else:
                    logger.warning("🧠 Multi-task format invalid - no JSON found")
                    logger.warning(f"🧠 Response text: {response_text}")
                    return self._fallback_multi_task(text)
            else:
                error_msg = result.get("error", "Unknown error")
                logger.warning(f"🧠 Multi-task parsing failed: {error_msg}")
                return self._fallback_multi_task(text)
            
        except Exception as e:
            logger.error(f"🧠 Multi-task parse error: {e}")
            return self._fallback_multi_task(text)
    
    def _format_context(self, context: Dict) -> str:
        """Форматирует контекст для промпта"""
        if not context:
            return "Контекст отсутствует"
        
        formatted = []
        for key, value in context.items():
            formatted.append(f"{key}: {value}")
        
        return "\n".join(formatted)
    
    def _format_history(self, history: List[str]) -> str:
        """Форматирует историю диалога"""
        if not history:
            return "История отсутствует"
        
        return "\n".join([f"- {msg}" for msg in history[-5:]])  # Последние 5 сообщений
    
    # Fallback методы
    def _fallback_food(self, text: str) -> Dict:
        """Fallback для парсера еды с низкой уверенностью"""
        return {
            "food_items": [{"name": text.strip(), "quantity": 100, "unit": "г", "preparation": "неизвестно"}],
            "meal_type": "неизвестно",
            "total_confidence": 25,  # Снижаем уверенность
            "needs_clarification": True  # Запрашиваем уточнение
        }
    
    def _fallback_water(self, text: str) -> Dict:
        """Fallback для парсера воды"""
        # Умная эвристика для определения количества
        text_lower = text.lower()
        amount_ml = 200  # по умолчанию
        
        if 'большую кружку' in text_lower or 'большая кружка' in text_lower:
            amount_ml = 300
        elif 'стакан' in text_lower or 'кружка' in text_lower:
            amount_ml = 250
        elif 'чашка' in text_lower:
            amount_ml = 200
        elif 'бутылка' in text_lower:
            amount_ml = 500
        elif 'полтора' in text_lower or '1.5' in text_lower:
            amount_ml = 1500
        elif 'литр' in text_lower or 'л' in text_lower:
            amount_ml = 1000
        
        return {
            "amount_ml": amount_ml,
            "confidence": 40,  # Снижаем уверенность
            "needs_clarification": True  # Запрашиваем уточнение
        }
    
    def _fallback_activity(self, text: str) -> Dict:
        """Fallback для парсера активности с низкой уверенностью"""
        text_lower = text.lower()
        
        # Базовые определения
        activity_type = "неизвестно"
        duration_minutes = 30
        calories_burned = 150
        
        # Умная эвристика
        if any(word in text_lower for word in ['бег', 'пробежка', 'jogging']):
            activity_type = "бег"
            duration_minutes = 30
            calories_burned = 300
        elif any(word in text_lower for word in ['ходьба', 'пешком', 'прогулка']):
            activity_type = "ходьба"
            duration_minutes = 45
            calories_burned = 150
        elif any(word in text_lower for word in ['велосипед', 'вело']):
            activity_type = "велосипед"
            duration_minutes = 30
            calories_burned = 250
        elif any(word in text_lower for word in ['плавание', 'бассейн']):
            activity_type = "плавание"
            duration_minutes = 30
            calories_burned = 350
        
        return {
            "activity_type": activity_type,
            "duration_minutes": duration_minutes,
            "calories_burned": calories_burned,
            "confidence": 35,  # Снижаем уверенность
            "needs_clarification": True  # Запрашиваем уточнение
        }

    return {
        "activity_type": activity_type,
        "duration_minutes": duration_minutes,
        "calories_burned": calories_burned,
        "confidence": 35,  # Снижаем уверенность
        "needs_clarification": True  # Запрашиваем уточнение
    }

def _fallback_intent(self, text: str) -> Dict:
    """Fallback для классификатора намерений с низкой уверенностью"""
    text_lower = text.lower()

    # Базовая эвристика
    intent = "other"
    confidence = 20  # Очень низкая уверенность

    if any(word in text_lower for word in ['съел', 'ел', 'завтрак', 'обед', 'ужин', 'питание']):
        intent = "food"
    elif any(word in text_lower for word in ['выпил', 'пил', 'вода', 'чай', 'кофе']):
        intent = "water"
    elif any(word in text_lower for word in ['бег', 'ходьба', 'спорт', 'тренировка']):
        intent = "activity"
    elif any(word in text_lower for word in ['вес', 'масса', 'кг']):
        intent = "weight"
    elif any(word in text_lower for word in ['шаги', 'шаг']):
        intent = "steps"
    elif any(word in text_lower for word in ['?', 'помощь', 'как', 'что', 'почему']):
        intent = "question"

    return {
        "intent": intent,
        "confidence": confidence,
        "needs_clarification": True  # Всегда запрашиваем уточнение
    }

def _fallback_multi_task(self, text: str) -> Dict:
    """Fallback для многозадачного парсера"""
    return {
        "intent": "other",
        "confidence": 30,
        "entities": {},
        "response": f"Я не понял '{text}'. Попробуйте переформулировать.",
        "actions": [],
        "needs_clarification": True
    }
            "confidence": 30,
            "entities": {},
            "response": f"Я не понял '{text}'. Попробуйте переформулировать.",
            "actions": [],
            "needs_clarification": True
        }

# Создаем экземпляр
enhanced_ai_parser = EnhancedAIParser()
